pipeline{
  agent any
  stages{
    stage('checkout'){
      steps{
       git url:'https://github.com/ruhi14547/my_first_repo.git',branch: 'master'
      }
    }
    stage('buils Image'){
      steps{
        bat 'docker build -t mywebsite .'
      }
    }
    stage('stop old containers'){
      steps(
        bat 'docker stop mycount || exit 0'
        bat 'docker rm mycount || exit 0'
        }
        }

        stage('Run Image - COntainerize')
        {
          steps{
            bat 'docker run -d -p 7000:80 --name mycount mywebsite'
          }
        }
        }
